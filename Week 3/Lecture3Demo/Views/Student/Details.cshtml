@model Lecture3Demo.ViewModels.StudentDetailsViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@Model.Title</title>
</head>
<body>
    <h1>@Model.Header</h1>

    <h2>Student Info</h2>
    <div>StudentId : @Model.Student?.StudentId</div>
    <div>Name : @Model.Student?.Name</div>
    <div>Branch : @Model.Student?.Branch</div>
    <div>Section : @Model.Student?.Section</div>
    <div>Gender : @Model.Student?.Gender</div>

    <h2>Address</h2>
    <div>Street : @Model.Address?.Street</div>
    <div>City : @Model.Address?.City</div>
    <div>Country : @Model.Address?.Country</div>
    <br />
    <a href="/">Back to Home</a>
</body>
</html>
