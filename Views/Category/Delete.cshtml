@model Category

<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-danger">Delete Category</h2>
        </div>
    </div>

    <form method="post">
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" disabled />
        </div>

        <div class="mb-3">
            <label asp-for="DisplayOrder" class="form-label"></label>
            <input asp-for="DisplayOrder" class="form-control" disabled />
        </div>

        <div>
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-controller="Category" asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </form>
</div>
